# QuantumNav Environmental Configuration
# Copy this file to .env.local and fill in the values for your environment

# Groq API Configuration (Required for AI traffic prediction features)
# Get your API key from: https://console.groq.com/keys
# This enables AI-powered traffic analysis and route recommendations
VITE_GROQ_API_KEY=your_groq_api_key_here

# Application Environment (automatically set by build tools)
# Development: npm run dev (enables logging, source maps)
# Production: npm run build (optimized, minified, no console logs)
# NODE_ENV is set automatically by Vite

# Optional: Analytics Configuration (currently disabled)
# VITE_ANALYTICS_ENABLED=false
# VITE_ANALYTICS_ID=your_analytics_id

# Optional: API Timeout Configuration (milliseconds)
# VITE_API_TIMEOUT=30000

# Optional: Default Map Center (Mumbai coordinates)
# VITE_MAP_CENTER_LAT=19.0760
# VITE_MAP_CENTER_LNG=72.8777
# VITE_MAP_ZOOM=12
